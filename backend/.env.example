# Backend environment variables for Render
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=hostel_finder
DB_USER=your-db-user
DB_PASS=your-db-password
DB_SSL=false

# If your Render backend is deployed under a subpath, set BASE_PATH.
# Usually leave empty when backend is served from the root domain.
BASE_PATH=
